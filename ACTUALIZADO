                    <button onclick="event.stopPropagation(); startTransition('${prod.id}', 'entregado')" class="flex items-center gap-1 px-2.5 py-1.5 bg-indigo-600 hover:bg-indigo-700 active:bg-indigo-800 text-white text-xs font-semibold rounded-lg shadow-sm transition-all ml-auto">
