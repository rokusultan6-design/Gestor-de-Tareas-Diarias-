        // Función para cambiar de forma dinámica marcas y accesorios
        function handleArticleTypeChange() {
            const articleTypeSelect = document.getElementById('prodArticleType');
            const articleCustomInput = document.getElementById('prodArticleTypeCustom');
            const brandSelect = document.getElementById('prodBrand');
            const brandCustomInput = document.getElementById('prodBrandCustom');
            const accContainer = document.getElementById('accessoriesContainer');
            const accessoryCustomInput = document.getElementById('prodAccessoryCustom');

            // Mostrar/Ocultar campo de texto personalizado si se selecciona "Otro" tipo de artículo
            if (articleTypeSelect.value === 'Otro') {
                articleCustomInput.classList.remove('hidden');
                articleCustomInput.required = true;
            } else {
                articleCustomInput.classList.add('hidden');
                articleCustomInput.required = false;
                articleCustomInput.value = '';
            }

            // Forzar reseteo de la marca personalizada al cambiar el tipo de artículo
            brandCustomInput.classList.add('hidden');
            brandCustomInput.required = false;
            brandCustomInput.value = '';

            // Forzar reseteo de accesorios personalizados
            accessoryCustomInput.classList.add('hidden');
            accessoryCustomInput.value = '';

            // Limpiar e Insertar Marcas adecuadas
            brandSelect.innerHTML = '';
            const config = ARTICLE_CONFIG[articleTypeSelect.value] || ARTICLE_CONFIG['Otro'];
            
            config.brands.forEach(brand => {
                const opt = document.createElement('option');
                opt.value = brand;
                opt.innerText = brand;
                brandSelect.appendChild(opt);
            });

            // Disparar validación de la marca inmediatamente después de cargar las nuevas opciones
            handleBrandChange();

            // Limpiar e Insertar Casillas de Verificación de Accesorios
            accContainer.innerHTML = '';
            config.accessories.forEach(acc => {
                const label = document.createElement('label');
                label.className = "flex items-center gap-2 cursor-pointer bg-white p-2 rounded-lg border border-slate-200 hover:bg-indigo-50/40 transition-colors shadow-sm select-none";
                
                const checkbox = document.createElement('input');
