        // Función para cambiar de forma dinámica marcas y accesorios
        function handleArticleTypeChange() {
            const articleType = document.getElementById('prodArticleType').value;
            const brandSelect = document.getElementById('prodBrand');
            const accContainer = document.getElementById('accessoriesContainer');

            // 1. Limpiar e Insertar Marcas adecuadas
            brandSelect.innerHTML = '';
