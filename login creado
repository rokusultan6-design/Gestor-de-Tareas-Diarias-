                } else if (prod.status === 'retornado') {
                    statusBadge = `<span class="px-2.5 py-1 bg-emerald-100 text-emerald-800 rounded-full text-[10px] font-bold border border-emerald-200 inline-flex items-center gap-1"><i data-lucide="check-circle" class="w-3 h-3"></i> 3. Retornado</span>`;
                } else if (prod.status === 'entregado') {
