                        currentSeq = num + 1;
                    }
                }
            });

            saveToStorage();
            buildStoreRadioButtons();
            renderBoard();
            handleArticleTypeChange();
            lucide.createIcons();
        }

        // Construir dinámicamente las opciones de tiendas en la creación de productos según los permisos
        function buildStoreRadioButtons() {
            const container = document.getElementById('storeRadioGroup');
            container.innerHTML = '';

            const allowed = currentUser ? currentUser.allowedStores : Object.keys(STORES_INFO);

            allowed.forEach((storeName, index) => {
                const label = document.createElement('label');
                label.className = "cursor-pointer";

                const isChecked = index === 0 ? "checked" : "";

                label.innerHTML = `
                    <input type="radio" name="store" value="${storeName}" ${isChecked} onchange="updateSelectedStoreInfo()" class="peer hidden">
                    <div class="border border-slate-200 rounded-lg py-2.5 px-2 text-center text-xs font-bold text-slate-600 peer-checked:border-indigo-600 peer-checked:bg-indigo-50 peer-checked:text-indigo-700 hover:bg-slate-50 transition-all shadow-sm">
                        ${storeName}
                    </div>
                `;
                container.appendChild(label);
            });

            updateSelectedStoreInfo();
        }

        // Actualiza dinámicamente la tarjeta de información al cambiar la tienda seleccionada
        function updateSelectedStoreInfo() {
            const selectedStoreRadio = document.querySelector('input[name="store"]:checked');
            const storeName = selectedStoreRadio ? selectedStoreRadio.value : (currentUser ? currentUser.allowedStores[0] : "Dos Hermanos");
            const info = STORES_INFO[storeName] || STORES_INFO["Dos Hermanos"];

            const nameEl = document.getElementById('previewStoreName');
            const addrEl = document.getElementById('previewStoreAddress');
            const phoneEl = document.getElementById('previewStorePhone');
            const emailEl = document.getElementById('previewStoreEmail');

            if (nameEl) nameEl.innerText = storeName;
            if (addrEl) addrEl.innerText = info.address;
            if (phoneEl) phoneEl.innerText = info.phone;
            if (emailEl) emailEl.innerText = info.email;

            lucide.createIcons();
        }

        function getNextReceiptCode() {
            let maxNum = -1;
            products.forEach(p => {
                if (p.receiptCode !== undefined && p.receiptCode !== null) {
                    const num = parseInt(p.receiptCode, 10);
                    if (!isNaN(num) && num > maxNum) {
                        maxNum = num;
                    }
                }
            });
            const nextNum = maxNum + 1;
            return String(nextNum).padStart(4, '0');
        }

        function saveToStorage() {
            localStorage.setItem('grupo_yousef_products', JSON.stringify(products));
        }

        function handleArticleTypeChange() {
            const articleTypeSelect = document.getElementById('prodArticleType');
            const articleCustomInput = document.getElementById('prodArticleTypeCustom');
            const brandSelect = document.getElementById('prodBrand');
            const brandCustomInput = document.getElementById('prodBrandCustom');
            const accContainer = document.getElementById('accessoriesContainer');
            const accessoryCustomInput = document.getElementById('prodAccessoryCustom');

            if (articleTypeSelect.value === 'Otro') {
                articleCustomInput.classList.remove('hidden');
                articleCustomInput.required = true;
            } else {
                articleCustomInput.classList.add('hidden');
                articleCustomInput.required = false;
                articleCustomInput.value = '';
            }

            brandCustomInput.classList.add('hidden');
            brandCustomInput.required = false;
            brandCustomInput.value = '';

            accessoryCustomInput.classList.add('hidden');
            accessoryCustomInput.value = '';

            brandSelect.innerHTML = '';
            const config = ARTICLE_CONFIG[articleTypeSelect.value] || ARTICLE_CONFIG['Otro'];
            
            config.brands.forEach(brand => {
                const opt = document.createElement('option');
                opt.value = brand;
                opt.innerText = brand;
                brandSelect.appendChild(opt);
            });

            handleBrandChange();

            accContainer.innerHTML = '';
            config.accessories.forEach(acc => {
                const label = document.createElement('label');
                label.className = "flex items-center gap-2 cursor-pointer bg-white p-2 rounded-lg border border-slate-200 hover:bg-indigo-50/40 transition-colors shadow-sm select-none";
                
                const checkbox = document.createElement('input');
                checkbox.type = "checkbox";
                checkbox.name = "prodAccessories";
                checkbox.value = acc;
                checkbox.className = "rounded text-indigo-600 focus:ring-indigo-500 w-4 h-4";

                if (acc === 'Otro') {
                    checkbox.onchange = function() {
                        if (this.checked) {
                            accessoryCustomInput.classList.remove('hidden');
                            accessoryCustomInput.focus();
                        } else {
                            accessoryCustomInput.classList.add('hidden');
                            accessoryCustomInput.value = '';
                        }
                    };
                }

                const span = document.createElement('span');
                span.className = "text-xs text-slate-700 font-semibold";
                span.innerText = acc;

                label.appendChild(checkbox);
                label.appendChild(span);
                accContainer.appendChild(label);
            });
        }

        function handleBrandChange() {
            const brandSelect = document.getElementById('prodBrand');
            const brandCustomInput = document.getElementById('prodBrandCustom');

            if (brandSelect && brandSelect.value === 'Otro') {
                brandCustomInput.classList.remove('hidden');
                brandCustomInput.required = true;
            } else if (brandCustomInput) {
                brandCustomInput.classList.add('hidden');
                brandCustomInput.required = false;
                brandCustomInput.value = '';
            }
        }

        function getDaysSinceActivityInWorkshop(prod) {
            if (prod.status !== 'taller') return 0;
            const startRef = prod.lastInquiryAt ? prod.lastInquiryAt : prod.enteredTallerAt;
            if (!startRef) return 0;

            const diffTime = Date.now() - new Date(startRef).getTime();
            return Math.floor(diffTime / (1000 * 60 * 60 * 24));
        }

        function filterProducts() {
            renderBoard();
        }

        // Renderizar el Tablero Kanban y Estadísticas Filtradas según Permisos de Tienda
        function renderBoard() {
            const colEntrada = document.getElementById('col-entrada');
            const colTaller = document.getElementById('col-taller');
            const colRetornado = document.getElementById('col-retornado');
            const colEntregado = document.getElementById('col-entregado');

            colEntrada.innerHTML = '';
            colTaller.innerHTML = '';
            colRetornado.innerHTML = '';
            colEntregado.innerHTML = '';

            let countEnt = 0, countTal = 0, countRet = 0, countEntregadoActivos = 0;
            let countFollowUpAlerts = 0;
            let totalAllowedProducts = 0;

            const searchQuery = document.getElementById('searchInput') ? document.getElementById('searchInput').value.toLowerCase().trim() : '';

            products.forEach(prod => {
                // FILTRADO POR PERMISOS DE TIENDA
                if (currentUser && !currentUser.allowedStores.includes(prod.store)) {
                    return; // No pertenece a las tiendas permitidas del usuario logueado
                }

                totalAllowedProducts++;

                if (prod.status === 'taller') {
                    const days = getDaysSinceActivityInWorkshop(prod);
                    if (days >= 5) {
                        countFollowUpAlerts++;
                    }
                }

                const card = createProductCard(prod);
                
                const matchesSearch = searchQuery === '' || 
                    prod.product.toLowerCase().includes(searchQuery) || 
                    (prod.receiptCode && prod.receiptCode.toLowerCase().includes(searchQuery)) ||
                    (prod.workshopOrderNumber && prod.workshopOrderNumber.toLowerCase().includes(searchQuery)) ||
                    (prod.repairDetails && prod.repairDetails.toLowerCase().includes(searchQuery)) ||
                    prod.serial.toLowerCase().includes(searchQuery) || 
                    prod.client.toLowerCase().includes(searchQuery) ||
                    (prod.phone && prod.phone.toLowerCase().includes(searchQuery)) ||
                    (prod.store && prod.store.toLowerCase().includes(searchQuery)) ||
                    prod.desc.toLowerCase().includes(searchQuery);

                if (prod.status === 'entrada') {
                    if (matchesSearch) {
                        colEntrada.appendChild(card);
                        countEnt++;
                    }
                } else if (prod.status === 'taller') {
                    if (matchesSearch) {
                        colTaller.appendChild(card);
                        countTal++;
                    }
                } else if (prod.status === 'retornado') {
                    if (matchesSearch) {
                        colRetornado.appendChild(card);
                        countRet++;
                    }
                } else if (prod.status === 'entregado') {
                    const timeElapsed = prod.deliveredAt ? (Date.now() - new Date(prod.deliveredAt).getTime()) : 0;
                    const isArchived = timeElapsed > ARCHIVE_TIMEOUT_MS;

                    if (searchQuery !== '') {
                        if (matchesSearch) {
                            colEntregado.appendChild(card);
                            countEntregadoActivos++;
                        }
                    } else {
                        if (!isArchived) {
                            colEntregado.appendChild(card);
                            countEntregadoActivos++;
                        }
                    }
                }
            });

            document.getElementById('countEntrada').innerText = countEnt;
            document.getElementById('countTaller').innerText = countTal;
            document.getElementById('countRetornado').innerText = countRet;
            document.getElementById('countEntregado').innerText = countEntregadoActivos;

            document.getElementById('statTotal').innerText = totalAllowedProducts;
            document.getElementById('statEntrada').innerText = countEnt;
            document.getElementById('statTaller').innerText = countTal;
            document.getElementById('statRetornado').innerText = countRet;
            document.getElementById('statEntregado').innerText = countEntregadoActivos;

            const followUpBanner = document.getElementById('followUpAlertBanner');
            const pendingBadge = document.getElementById('pendingAlertsBadge');
            if (countFollowUpAlerts > 0) {
                followUpBanner.classList.remove('hidden');
                pendingBadge.innerText = `${countFollowUpAlerts} equipo(s) con alerta`;
            } else {
                followUpBanner.classList.add('hidden');
            }

            // Si el modal de historial total está abierto, re-renderizarlo
            const modalHistory = document.getElementById('modalFullHistory');
            if (modalHistory && !modalHistory.classList.contains('hidden')) {
                renderHistoryTable();
            }

            lucide.createIcons();
        }

        // FUNCIONALIDAD DEL HISTORIAL TOTAL EN MODAL CON FILTRADO POR TIENDA
