            }

            // Etiqueta especial si está archivado de forma automática
            let archiveIndicator = '';
            if (prod.status === 'entregado') {
                const timeElapsed = prod.deliveredAt ? (Date.now() - new Date(prod.deliveredAt).getTime()) : 0;
                if (timeElapsed > ARCHIVE_TIMEOUT_MS) {
