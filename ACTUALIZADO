<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TallerFlow - Control de Entradas y Taller</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Lucide Icons para un diseño moderno -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
        body {
            font-family: 'Inter', sans-serif;
        }
        /* Personalización de barra de scroll fina */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        ::-webkit-scrollbar-track {
            background: transparent;
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 min-h-screen flex flex-col">

    <!-- Header / Navbar -->
    <header class="bg-white border-b border-slate-200 sticky top-0 z-40 shadow-sm">
        <div class="max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-8 py-4 flex flex-col md:flex-row items-center justify-between gap-4">
            <div class="flex items-center gap-3">
                <div class="p-2.5 bg-indigo-600 text-white rounded-xl shadow-md shadow-indigo-100">
                    <i data-lucide="wrench" class="w-6 h-6"></i>
                </div>
                <div>
                    <h1 class="text-xl font-bold text-slate-900 tracking-tight">TallerFlow</h1>
                    <p class="text-xs text-slate-500 font-medium">Control de Entradas, Diagnósticos, Retornos y Entregas</p>
                </div>
            </div>
            
            <div class="flex items-center gap-3 w-full md:w-auto">
                <!-- Buscador rápido por producto, serie o cliente -->
                <div class="relative flex-1 md:flex-initial">
                    <span class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-slate-400">
                        <i data-lucide="search" class="w-4 h-4"></i>
                    </span>
                    <input type="text" id="searchInput" oninput="filterProducts()" placeholder="Buscar por S/N, cliente, artículo..." class="w-full md:w-96 pl-9 pr-4 py-2 bg-slate-100 border border-transparent rounded-lg text-sm focus:bg-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 outline-none transition-all">
                </div>
                <!-- Botón de Ingreso de Producto -->
                <button onclick="openNewProductModal()" class="flex items-center justify-center gap-2 px-4 py-2 bg-indigo-600 hover:bg-indigo-700 active:bg-indigo-800 text-white text-sm font-semibold rounded-lg shadow-lg shadow-indigo-100 transition-all w-full md:w-auto">
                    <i data-lucide="plus" class="w-4 h-4"></i>
                    <span>Registrar Ingreso</span>
                </button>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="flex-1 max-w-[1600px] w-full mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col gap-6">
        
        <!-- Dashboard / Panel de Estadísticas Adaptado -->
        <div class="grid grid-cols-2 lg:grid-cols-5 gap-4 bg-white p-4 rounded-xl border border-slate-200 shadow-sm">
            <div class="p-3 bg-slate-50 rounded-lg flex items-center gap-3">
                <div class="p-2 bg-slate-200 text-slate-700 rounded-lg">
                    <i data-lucide="package" class="w-5 h-5"></i>
                </div>
                <div>
                    <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Historial Total</p>
                    <h3 id="statTotal" class="text-lg font-bold text-slate-800 font-mono">0</h3>
                </div>
            </div>
            <div class="p-3 bg-slate-50 rounded-lg flex items-center gap-3">
                <div class="p-2 bg-sky-100 text-sky-600 rounded-lg">
                    <i data-lucide="clipboard-list" class="w-5 h-5"></i>
                </div>
                <div>
                    <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider">En Entrada/Espera</p>
                    <h3 id="statEntrada" class="text-lg font-bold text-sky-700 font-mono">0</h3>
                </div>
            </div>
            <div class="p-3 bg-slate-50 rounded-lg flex items-center gap-3">
                <div class="p-2 bg-amber-100 text-amber-600 rounded-lg">
                    <i data-lucide="cog" class="w-5 h-5"></i>
                </div>
                <div>
                    <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider">En Taller</p>
                    <h3 id="statTaller" class="text-lg font-bold text-amber-700 font-mono">0</h3>
                </div>
            </div>
            <div class="p-3 bg-slate-50 rounded-lg flex items-center gap-3">
                <div class="p-2 bg-emerald-100 text-emerald-600 rounded-lg">
                    <i data-lucide="check-circle" class="w-5 h-5"></i>
                </div>
                <div>
                    <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Listo p/ Entrega</p>
                    <h3 id="statRetornado" class="text-lg font-bold text-emerald-700 font-mono">0</h3>
                </div>
            </div>
            <div class="p-3 bg-slate-50 rounded-lg flex items-center gap-3 col-span-2 lg:col-span-1">
                <div class="p-2 bg-indigo-100 text-indigo-600 rounded-lg">
                    <i data-lucide="user-check" class="w-5 h-5"></i>
                </div>
                <div>
                    <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Entregados Activos</p>
                    <h3 id="statEntregado" class="text-lg font-bold text-indigo-700 font-mono">0</h3>
                </div>
            </div>
        </div>

        <!-- Kanban Grid para Procesos de Taller (4 Columnas) -->
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6 flex-1 items-start">
            
            <!-- COLUMNA 1: ENTRADA DE PRODUCTO -->
            <div class="bg-slate-100 rounded-2xl p-4 border border-slate-200 shadow-inner flex flex-col max-h-[75vh]">
                <div class="flex items-center justify-between pb-3 border-b border-slate-200 mb-4 px-1">
                    <div class="flex items-center gap-2">
                        <span class="w-2.5 h-2.5 rounded-full bg-sky-500 animate-pulse"></span>
                        <h2 class="font-bold text-slate-700 text-sm">1. Entrada / Recepción</h2>
                        <span id="countEntrada" class="ml-1 text-xs px-2 py-0.5 bg-sky-100 text-sky-700 rounded-full font-bold">0</span>
                    </div>
                </div>
                <div id="col-entrada" class="space-y-3 overflow-y-auto pr-1 flex-1 min-h-[250px]" ondragover="allowDrop(event)" ondrop="handleDrop(event, 'entrada')">
                    <!-- Productos dinámicos -->
                </div>
            </div>

            <!-- COLUMNA 2: EN TALLER -->
            <div class="bg-slate-100 rounded-2xl p-4 border border-slate-200 shadow-inner flex flex-col max-h-[75vh]">
                <div class="flex items-center justify-between pb-3 border-b border-slate-200 mb-4 px-1">
                    <div class="flex items-center gap-2">
                        <span class="w-2.5 h-2.5 rounded-full bg-amber-500 animate-pulse"></span>
                        <h2 class="font-bold text-slate-700 text-sm">2. En Taller</h2>
                        <span id="countTaller" class="ml-1 text-xs px-2 py-0.5 bg-amber-100 text-amber-700 rounded-full font-bold">0</span>
                    </div>
                </div>
                <div id="col-taller" class="space-y-3 overflow-y-auto pr-1 flex-1 min-h-[250px]" ondragover="allowDrop(event)" ondrop="handleDrop(event, 'taller')">
                    <!-- Productos dinámicos -->
                </div>
            </div>

            <!-- COLUMNA 3: RETORNADO DE TALLER -->
            <div class="bg-slate-100 rounded-2xl p-4 border border-slate-200 shadow-inner flex flex-col max-h-[75vh]">
                <div class="flex items-center justify-between pb-3 border-b border-slate-200 mb-4 px-1">
                    <div class="flex items-center gap-2">
                        <span class="w-2.5 h-2.5 rounded-full bg-emerald-500 animate-pulse"></span>
                        <h2 class="font-bold text-slate-700 text-sm">3. Retornado / Listo</h2>
                        <span id="countRetornado" class="ml-1 text-xs px-2 py-0.5 bg-emerald-100 text-emerald-700 rounded-full font-bold">0</span>
                    </div>
                </div>
                <div id="col-retornado" class="space-y-3 overflow-y-auto pr-1 flex-1 min-h-[250px]" ondragover="allowDrop(event)" ondrop="handleDrop(event, 'retornado')">
                    <!-- Productos dinámicos -->
                </div>
            </div>

            <!-- COLUMNA 4: ENTREGADO A CLIENTE -->
            <div class="bg-slate-100 rounded-2xl p-4 border border-slate-200 shadow-inner flex flex-col max-h-[75vh]">
                <div class="flex flex-col pb-3 border-b border-slate-200 mb-4 px-1 gap-1">
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-2">
                            <span class="w-2.5 h-2.5 rounded-full bg-indigo-500 animate-pulse"></span>
                            <h2 class="font-bold text-slate-700 text-sm">4. Entregado a Cliente</h2>
                            <span id="countEntregado" class="ml-1 text-xs px-2 py-0.5 bg-indigo-100 text-indigo-700 rounded-full font-bold">0</span>
                        </div>
                    </div>
                    <span class="text-[9px] text-slate-500 italic leading-none font-medium mt-0.5">Auto-archivado a las 24 hrs. Búsqueda por S/N permanente.</span>
                </div>
                <div id="col-entregado" class="space-y-3 overflow-y-auto pr-1 flex-1 min-h-[250px]" ondragover="allowDrop(event)" ondrop="handleDrop(event, 'entregado')">
                    <!-- Productos dinámicos -->
                </div>
            </div>

        </div>
    </main>

    <!-- MODAL: REGISTRAR INGRESO (NUEVO PRODUCTO) -->
    <div id="modalNewProduct" class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm z-50 flex items-center justify-center hidden p-4">
        <div class="bg-white rounded-2xl shadow-xl border border-slate-100 w-full max-w-lg transform scale-95 transition-all duration-300 overflow-hidden">
            <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between bg-indigo-50/50">
                <div class="flex items-center gap-2 text-indigo-700">
                    <i data-lucide="plus-circle" class="w-5 h-5"></i>
                    <h3 class="font-bold text-slate-900 font-sans">Registrar Ingreso de Producto</h3>
                </div>
                <button onclick="closeNewProductModal()" class="text-slate-400 hover:text-slate-600 p-1 rounded-lg hover:bg-slate-100 transition-all">
                    <i data-lucide="x" class="w-5 h-5"></i>
                </button>
            </div>
            <form id="productForm" onsubmit="saveProduct(event)" class="p-6 space-y-4">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-[11px] font-bold uppercase tracking-wider text-slate-500 mb-1">Tipo de Artículo</label>
                        <select id="prodArticleType" onchange="handleArticleTypeChange()" class="w-full px-3.5 py-2 border border-slate-200 rounded-lg text-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none bg-white transition-all">
                            <option value="Televisor">Televisor</option>
                            <option value="Microondas">Microondas</option>
                            <option value="Oasis">Oasis</option>
                            <option value="Ventilador">Ventilador</option>
                            <option value="Licuadora">Licuadora</option>
                            <option value="Otro">Otro</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-[11px] font-bold uppercase tracking-wider text-slate-500 mb-1">Marca</label>
                        <select id="prodBrand" class="w-full px-3.5 py-2 border border-slate-200 rounded-lg text-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none bg-white transition-all">
                            <!-- Opciones dinámicas cargadas por JS -->
                        </select>
                    </div>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-[11px] font-bold uppercase tracking-wider text-slate-500 mb-1">Modelo / Detalle de Producto</label>
                        <input type="text" id="prodModel" required placeholder="Ej: Smart TV 55'' / Mod: X3" class="w-full px-3.5 py-2 border border-slate-200 rounded-lg text-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none transition-all">
                    </div>
                    <div>
                        <label class="block text-[11px] font-bold uppercase tracking-wider text-slate-500 mb-1">Número de Serie / ID único</label>
                        <input type="text" id="prodSerial" required placeholder="Ej: SN-49204A81" class="w-full px-3.5 py-2 border border-slate-200 rounded-lg text-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none transition-all">
                    </div>
                </div>

                <div>
                    <label class="block text-[11px] font-bold uppercase tracking-wider text-slate-500 mb-1">Accesorios Entregados</label>
                    <div id="accessoriesContainer" class="grid grid-cols-2 sm:grid-cols-3 gap-2 bg-slate-50 p-3 rounded-lg border border-slate-200">
                        <!-- Casillas de verificación dinámicas según el artículo -->
                    </div>
                </div>

                <div>
                    <label class="block text-[11px] font-bold uppercase tracking-wider text-slate-500 mb-1">Nombre del Cliente / Propietario</label>
                    <input type="text" id="prodClient" required placeholder="Ej: Carlos Mendoza" class="w-full px-3.5 py-2 border border-slate-200 rounded-lg text-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none transition-all">
                </div>

                <div>
                    <label class="block text-[11px] font-bold uppercase tracking-wider text-slate-500 mb-1">Falla Reportada o Diagnóstico Inicial</label>
                    <textarea id="prodDesc" rows="3" required placeholder="Ej: No enciende, parpadea luz LED blanca..." class="w-full px-3.5 py-2 border border-slate-200 rounded-lg text-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none transition-all"></textarea>
                </div>

                <div>
                    <label class="block text-[11px] font-bold uppercase tracking-wider text-slate-500 mb-1">Prioridad de Reparación</label>
                    <div class="grid grid-cols-3 gap-2">
                        <label class="border border-slate-200 rounded-lg py-2 flex items-center justify-center gap-2 cursor-pointer hover:bg-slate-50 transition-all">
                            <input type="radio" name="priority" value="Baja" checked class="text-emerald-500 focus:ring-emerald-400">
                            <span class="text-xs font-semibold text-slate-600">Baja</span>
                        </label>
                        <label class="border border-slate-200 rounded-lg py-2 flex items-center justify-center gap-2 cursor-pointer hover:bg-slate-50 transition-all">
                            <input type="radio" name="priority" value="Media" class="text-amber-500 focus:ring-amber-400">
                            <span class="text-xs font-semibold text-slate-600">Media</span>
                        </label>
                        <label class="border border-slate-200 rounded-lg py-2 flex items-center justify-center gap-2 cursor-pointer hover:bg-slate-50 transition-all">
                            <input type="radio" name="priority" value="Alta" class="text-rose-500 focus:ring-rose-400">
                            <span class="text-xs font-semibold text-slate-600">Alta</span>
                        </label>
                    </div>
                </div>

                <div class="pt-2 flex justify-end gap-3 border-t border-slate-100">
                    <button type="button" onclick="closeNewProductModal()" class="px-4 py-2 bg-slate-100 hover:bg-slate-200 rounded-lg text-xs font-semibold text-slate-600 transition-all">Cancelar</button>
                    <button type="submit" class="px-4 py-2 bg-indigo-600 hover:bg-indigo-700 active:bg-indigo-800 text-white text-xs font-semibold rounded-lg shadow-md transition-all">Registrar Entrada</button>
                </div>
            </form>
        </div>
    </div>

    <!-- MODAL: COMENTARIO OBLIGATORIO DE CAMBIO DE ESTADO -->
    <div id="modalTransition" class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm z-50 flex items-center justify-center hidden p-4">
        <div class="bg-white rounded-2xl shadow-xl border border-slate-100 w-full max-w-md transform scale-95 transition-all duration-300 overflow-hidden">
            <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between bg-amber-50/50">
                <div class="flex items-center gap-2 text-amber-700">
                    <i data-lucide="message-square" class="w-5 h-5"></i>
                    <h3 class="font-bold text-slate-900">Registrar Bitácora de Transición</h3>
                </div>
                <button onclick="cancelTransition()" class="text-slate-400 hover:text-slate-600 p-1 rounded-lg hover:bg-slate-100 transition-all">
                    <i data-lucide="x" class="w-5 h-5"></i>
                </button>
            </div>
            <div class="p-6 space-y-4">
                <p id="transitionNotice" class="text-sm text-slate-600 font-medium bg-slate-50 p-3 rounded-lg border border-slate-200">
                    Estás a punto de pasar el producto.
                </p>

                <!-- Selección de Destino de Taller (Solo visible al mandar a Taller) -->
                <div id="workshopSelectBlock" class="hidden">
                    <label class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1">Seleccionar Taller de Destino</label>
                    <select id="transitionWorkshop" class="w-full px-3.5 py-2 border border-slate-200 rounded-lg text-sm focus:border-amber-500 focus:ring-2 focus:ring-amber-100 outline-none bg-white transition-all">
                        <option value="LATIN">LATIN</option>
                        <option value="SERVITECA">SERVITECA</option>
                        <option value="INTERNO">INTERNO</option>
                    </select>
                </div>
                
                <div>
                    <label class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-1">Comentario sobre el estado / entrega (Obligatorio)</label>
                    <textarea id="transitionComment" rows="3" placeholder="Escribe el diagnóstico, notas de entrega, conformidad del cliente..." class="w-full px-3.5 py-2 border border-slate-200 rounded-lg text-sm focus:border-amber-500 focus:ring-2 focus:ring-amber-100 outline-none transition-all"></textarea>
                    <p id="transitionErrorMsg" class="text-xs text-rose-500 mt-1 font-semibold hidden">Debes agregar un comentario para cambiar el estado del equipo.</p>
                </div>

                <!-- Plantillas de Comentarios Rápidos para Taller -->
                <div>
                    <p class="text-[10px] font-bold text-slate-400 uppercase mb-2">Comentarios rápidos recomendados:</p>
                    <div id="quickComments" class="flex flex-wrap gap-1.5 font-sans">
                        <!-- Botones rápidos generados por JS -->
                    </div>
                </div>

                <div class="pt-2 flex justify-end gap-3 border-t border-slate-100">
                    <button type="button" onclick="cancelTransition()" class="px-4 py-2 bg-slate-100 hover:bg-slate-200 rounded-lg text-xs font-semibold text-slate-600 transition-all">Cancelar</button>
                    <button type="button" onclick="confirmTransition()" class="px-4 py-2 bg-amber-600 hover:bg-amber-700 active:bg-amber-800 text-white text-xs font-semibold rounded-lg shadow-md transition-all">Confirmar Cambio de Estado</button>
                </div>
            </div>
        </div>
    </div>

    <!-- MODAL: DETALLES DE PRODUCTO E HISTORIAL COMPLETO -->
    <div id="modalDetails" class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm z-50 flex items-center justify-center hidden p-4">
        <div class="bg-white rounded-2xl shadow-xl border border-slate-100 w-full max-w-xl transform scale-95 transition-all duration-300 overflow-hidden flex flex-col max-h-[90vh]">
            <!-- Header -->
            <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
                <div class="flex items-center gap-2">
                    <span id="detailPriority" class="text-xs px-2.5 py-0.5 rounded-full font-bold">Media</span>
                    <span id="detailStatus" class="text-xs px-2.5 py-0.5 rounded-full font-bold">En Taller</span>
                </div>
                <button onclick="closeDetailsModal()" class="text-slate-400 hover:text-slate-600 p-1 rounded-lg hover:bg-slate-100 transition-all">
                    <i data-lucide="x" class="w-5 h-5"></i>
                </button>
            </div>
            
            <!-- Contenido scrollable -->
            <div class="p-6 space-y-6 overflow-y-auto flex-1">
                <div>
                    <div class="flex items-center gap-2 flex-wrap">
                        <h2 id="detailTitle" class="text-xl font-bold text-slate-900 mb-1 leading-tight">Laptop HP Pavilion</h2>
                        <span id="detailWorkshopBadge" class="hidden text-xs px-2.5 py-0.5 rounded-full font-bold"></span>
                    </div>
                    <div id="detailSpecsBlock" class="grid grid-cols-2 gap-3 bg-indigo-50/30 p-3 rounded-xl border border-indigo-100 text-xs mt-3">
                        <div>
                            <span class="text-slate-400 font-bold uppercase tracking-wider text-[9px] block">Artículo</span>
                            <span id="detailArticleType" class="text-slate-800 font-semibold text-sm">Cargando...</span>
                        </div>
                        <div>
                            <span class="text-slate-400 font-bold uppercase tracking-wider text-[9px] block">Marca</span>
                            <span id="detailBrand" class="text-slate-800 font-semibold text-sm">Cargando...</span>
                        </div>
                    </div>

                    <div class="flex flex-col sm:flex-row gap-2 sm:gap-4 text-xs text-slate-500 mt-4 pb-4 border-b border-slate-100">
                        <span class="flex items-center gap-1"><i data-lucide="barcode" class="w-3.5 h-3.5"></i> <strong class="text-slate-700">S/N:</strong> <span id="detailSerial" class="font-mono font-medium">SN-00000</span></span>
                        <span class="flex items-center gap-1"><i data-lucide="user" class="w-3.5 h-3.5"></i> <strong class="text-slate-700">Cliente:</strong> <span id="detailClient" class="font-medium">Desconocido</span></span>
                    </div>

                    <div class="mt-4">
                        <h4 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2 flex items-center gap-1">
                            <i data-lucide="package-open" class="w-3.5 h-3.5"></i> Accesorios Entregados
                        </h4>
                        <div id="detailAccessories" class="flex flex-wrap gap-1.5 p-2 bg-slate-50 rounded-lg border border-slate-200">
                            <!-- Se renderizará en JS -->
                        </div>
                    </div>

                    <div class="mt-4">
                        <h4 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-1">Descripción / Falla inicial:</h4>
                        <p id="detailDesc" class="text-sm text-slate-600 whitespace-pre-line leading-relaxed bg-slate-50 p-3 rounded-lg border border-slate-150">Diagnóstico detallado.</p>
                    </div>
                </div>

                <div class="border-t border-slate-100 pt-4">
                    <h4 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-3 flex items-center gap-1.5">
                        <i data-lucide="history" class="w-4 h-4 text-slate-500"></i>
                        Bitácora de Seguimiento de Taller
                    </h4>
                    
                    <!-- Timeline / Historial del equipo -->
                    <div id="detailTimeline" class="space-y-4 relative before:absolute before:inset-y-0 before:left-3 before:w-0.5 before:bg-slate-200">
                        <!-- Items de historial cargados por JS -->
                    </div>
                </div>
            </div>

            <!-- Footer: Comentarios rápidos directos -->
            <div class="p-4 bg-slate-50 border-t border-slate-100 flex flex-col gap-2">
                <div class="flex gap-2">
