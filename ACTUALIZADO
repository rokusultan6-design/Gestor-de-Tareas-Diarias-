        // Abrir Modal de Registro de Entrada
        function openNewProductModal() {
            document.getElementById('modalNewProduct').classList.remove('hidden');
            document.getElementById('prodArticleType').value = "Televisor";
            handleArticleTypeChange();
        }

        // Cerrar Modal de Registro
        function closeNewProductModal() {
            document.getElementById('modalNewProduct').classList.add('hidden');
            document.getElementById('productForm').reset();
        }

        // Guardar Nuevo Registro de Producto con marca, tipo y accesorios
        function saveProduct(e) {
            e.preventDefault();
            const articleType = document.getElementById('prodArticleType').value;
            const brand = document.getElementById('prodBrand').value;
            const model = document.getElementById('prodModel').value.trim();
            const serial = document.getElementById('prodSerial').value.trim();
            const client = document.getElementById('prodClient').value.trim();
            const desc = document.getElementById('prodDesc').value.trim();
            const priority = document.querySelector('input[name="priority"]:checked').value;

            // Recopilar accesorios marcados
            const checkboxElements = document.querySelectorAll('input[name="prodAccessories"]:checked');
            const accessories = Array.from(checkboxElements).map(cb => cb.value);

            if (!model || !serial || !client || !desc) return;

            // Nombre compuesto para la tarjeta principal
            const computedName = `${articleType} ${brand} - ${model}`;

            const newProduct = {
                id: 'prod-' + Date.now(),
                product: computedName,
                articleType: articleType,
                brand: brand,
                model: model,
                accessories: accessories,
                serial: serial,
                client: client,
                desc: desc,
                priority: priority,
                status: 'entrada',
                createdAt: new Date().toISOString(),
                history: [
                    {
                        timestamp: new Date().toISOString(),
                        text: `Ingreso registrado. Tipo: ${articleType}, Marca: ${brand}. Accesorios recibidos: [${accessories.join(', ') || 'Ninguno'}]. Diagnóstico inicial: "${desc}"`,
                        type: "create",
                        from: null,
                        to: "entrada"
                    }
                ]
            };

            products.push(newProduct);
            saveToStorage();
            renderBoard();
            closeNewProductModal();
        }

        // Iniciar la transición de columna (Pide comentario de taller obligatorio)
        function startTransition(productId, targetStatus) {
            const prod = products.find(p => p.id === productId);
            if (!prod) return;

            pendingTransition = { productId, targetStatus };

            // Ocultar mensaje de error anterior
            document.getElementById('transitionErrorMsg').classList.add('hidden');

            // Mostrar/Ocultar el bloque de selección de taller
            const wsBlock = document.getElementById('workshopSelectBlock');
            if (targetStatus === 'taller') {
                wsBlock.classList.remove('hidden');
                document.getElementById('transitionWorkshop').value = prod.workshop || 'LATIN';
            } else {
                wsBlock.classList.add('hidden');
            }

            const fromPretty = getStatusPrettyName(prod.status);
            const toPretty = getStatusPrettyName(targetStatus);
            document.getElementById('transitionNotice').innerHTML = `
                Moviendo el equipo <strong class="text-slate-800">"${prod.product}"</strong> (S/N: ${prod.serial}) de: 
                <span class="px-2 py-0.5 rounded bg-slate-200 text-slate-800 font-bold text-xs">${fromPretty}</span> a 
                <span class="px-2 py-0.5 rounded bg-indigo-100 text-indigo-800 font-bold text-xs">${toPretty}</span>.
            `;

            // Configurar comentarios rápidos basados en la transición de estado específica
            const quickCommentsBox = document.getElementById('quickComments');
            quickCommentsBox.innerHTML = '';
            
            const commentsTemplates = getQuickCommentTemplates(prod.status, targetStatus);
            commentsTemplates.forEach(comment => {
                const btn = document.createElement('button');
                btn.type = 'button';
                btn.onclick = () => { 
                    document.getElementById('transitionComment').value = comment; 
                    document.getElementById('transitionErrorMsg').classList.add('hidden');
                };
                btn.className = "text-[11px] bg-slate-100 hover:bg-slate-200 text-slate-600 font-medium px-2.5 py-1 rounded border border-slate-200 transition-all text-left";
                btn.innerText = comment;
                quickCommentsBox.appendChild(btn);
            });

            // Limpiar área de texto
            document.getElementById('transitionComment').value = '';

            // Mostrar modal
            document.getElementById('modalTransition').classList.remove('hidden');
        }

        // Cancelar el movimiento de columna
        function cancelTransition() {
            pendingTransition = null;
            document.getElementById('modalTransition').classList.add('hidden');
        }

        // Confirmar el cambio de estado con comentario validado (Sin alertas estándar)
        function confirmTransition() {
            const commentText = document.getElementById('transitionComment').value.trim();
            if (!commentText) {
                document.getElementById('transitionErrorMsg').classList.remove('hidden');
                return;
            }

            if (!pendingTransition) return;

            const { productId, targetStatus } = pendingTransition;
            const prod = products.find(p => p.id === productId);

            if (prod) {
                const oldStatus = prod.status;
                let finalComment = commentText;

                // Si va a taller, registrar a qué taller se destina
                if (targetStatus === 'taller') {
                    const selectedWorkshop = document.getElementById('transitionWorkshop').value;
                    prod.workshop = selectedWorkshop;
                    finalComment = `[Enviado a Taller: ${selectedWorkshop}] ${commentText}`;
                } else if (targetStatus === 'retornado') {
                    if (prod.workshop) {
                        finalComment = `[Regresa de Taller: ${prod.workshop}] ${commentText}`;
                    }
                    prod.workshop = null;
                } else if (targetStatus === 'entrada') {
                    prod.workshop = null;
                } else if (targetStatus === 'entregado') {
                    // Sellar fecha exacta de entrega para control de archivado autónomo
                    prod.deliveredAt = new Date().toISOString();
                    prod.workshop = null;
                    finalComment = `[ENTREGADO A CLIENTE] ${commentText}`;
                }

                // Actualizar estado en el sistema
                prod.status = targetStatus;
                // Grabar logs e historial
                prod.history.push({
                    timestamp: new Date().toISOString(),
                    text: finalComment,
                    type: "transition",
                    from: oldStatus,
                    to: targetStatus
                });

                saveToStorage();
                renderBoard();

                if (currentViewingProductId === productId) {
                    openDetailsModal(productId);
                }
            }

            pendingTransition = null;
            document.getElementById('modalTransition').classList.add('hidden');
        }

        // Retornar nombres de estado para la vista de usuario
        function getStatusPrettyName(status) {
            switch(status) {
                case 'entrada': return 'Entrada / Recepción';
                case 'taller': return 'En Taller (Servicio)';
                case 'retornado': return 'Retornado de Taller';
                case 'entregado': return 'Entregado a Cliente';
                default: return status;
            }
        }

        // Plantillas rápidas de comentarios específicos para flujos de servicio técnico
        function getQuickCommentTemplates(from, to) {
            if (from === 'entrada' && to === 'taller') {
                return [
                    "Asignado a mesa de taller para revisión diagnóstica inicial.",
                    "Iniciando desensamble y limpieza interna.",
                    "Equipo ingresa al taller para pruebas de voltaje."
                ];
            } else if (from === 'taller' && to === 'retornado') {
                return [
                    "Reparación exitosa. Pruebas de funcionamiento aprobadas.",
                    "Mantenimiento completado y equipo sellado para su retiro.",
                    "Instalación de componentes de repuesto verificada."
                ];
            } else if (from === 'taller' && to === 'entrada') {
                return [
                    "Regresa a recepción en espera de repuestos.",
                    "Se devuelve a recepción a espera de aprobación de presupuesto.",
                    "Detención de trabajo por prioridad de urgencia."
                ];
            } else if (from === 'retornado' && to === 'taller') {
                return [
                    "Reingreso por garantía o reporte de fallas secundarias.",
                    "Se reabre el ticket para verificación preventiva técnica."
                ];
            } else if (to === 'entregado') {
                return [
                    "Equipo entregado al cliente en óptimas condiciones. Satisfecho con las pruebas.",
                    "Se entrega equipo junto con los accesorios recibidos en recepción.",
                    "Cliente retira el artículo, pago procesado correctamente."
                ];
            }
            return ["Registro de actualización en bitácora."];
        }

        // Eventos de Drag and Drop
        function allowDrop(ev) {
            ev.preventDefault();
        }

        function handleDragStart(ev, productId) {
            ev.dataTransfer.setData("text/plain", productId);
        }

        function handleDrop(ev, targetStatus) {
            ev.preventDefault();
            const productId = ev.dataTransfer.getData("text/plain");
            const prod = products.find(p => p.id === productId);
            
            if (prod && prod.status !== targetStatus) {
                startTransition(productId, targetStatus);
            }
        }

        // Abrir Detalle y Timeline Completo del Producto
        function openDetailsModal(productId) {
            const prod = products.find(p => p.id === productId);
            if (!prod) return;

            currentViewingProductId = productId;

            // Renderizado de datos primarios
            document.getElementById('detailTitle').innerText = prod.product;
            document.getElementById('detailSerial').innerText = prod.serial;
            document.getElementById('detailClient').innerText = prod.client;
            document.getElementById('detailDesc').innerText = prod.desc;

            document.getElementById('detailArticleType').innerText = prod.articleType || "No especificado";
            document.getElementById('detailBrand').innerText = prod.brand || "No especificada";

            // Renderizar la insignia del taller en los detalles si está asignado
            const wsDetailBadge = document.getElementById('detailWorkshopBadge');
            if (prod.workshop) {
                wsDetailBadge.innerText = `Taller: ${prod.workshop}`;
                wsDetailBadge.className = "text-xs px-2.5 py-0.5 rounded-full font-bold bg-indigo-100 text-indigo-800 border border-indigo-200";
                wsDetailBadge.classList.remove('hidden');
            } else {
                wsDetailBadge.classList.add('hidden');
            }

            // Renderizado de Accesorios en el modal
            const accessoriesBox = document.getElementById('detailAccessories');
            accessoriesBox.innerHTML = '';
            if (prod.accessories && prod.accessories.length > 0) {
                prod.accessories.forEach(acc => {
                    const span = document.createElement('span');
                    span.className = "text-xs font-bold bg-indigo-50 text-indigo-700 px-2.5 py-1 rounded-md border border-indigo-100 flex items-center gap-1 shadow-sm";
                    span.innerHTML = `<i data-lucide="check-square" class="w-3.5 h-3.5 text-indigo-500"></i> ${acc}`;
                    accessoriesBox.appendChild(span);
                });
            } else {
                accessoriesBox.innerHTML = `<span class="text-xs italic text-slate-400 p-1">El equipo ingresó sin accesorios.</span>`;
            }

            // Badge Prioridad
            const pBadge = document.getElementById('detailPriority');
            pBadge.innerText = prod.priority;
            pBadge.className = "text-xs px-2.5 py-0.5 rounded-full font-bold " + 
                (prod.priority === 'Alta' ? 'bg-rose-100 text-rose-800' : 
                 prod.priority === 'Media' ? 'bg-amber-100 text-amber-800' : 'bg-emerald-100 text-emerald-800');

            // Badge Estado
            const sBadge = document.getElementById('detailStatus');
            sBadge.innerText = getStatusPrettyName(prod.status);
            sBadge.className = "text-xs px-2.5 py-0.5 rounded-full font-bold " + 
                (prod.status === 'entrada' ? 'bg-sky-100 text-sky-800' : 
                 prod.status === 'taller' ? 'bg-amber-100 text-amber-800' : 
                 prod.status === 'retornado' ? 'bg-emerald-100 text-emerald-800' : 'bg-indigo-100 text-indigo-800');

            // Cargar Línea de Tiempo de Bitácora
            const timelineContainer = document.getElementById('detailTimeline');
            timelineContainer.innerHTML = '';

            prod.history.forEach((log, index) => {
                const item = document.createElement('div');
                item.className = "relative pl-8 pb-3";

                const logDate = new Date(log.timestamp);
                const dateString = logDate.toLocaleDateString('es-ES', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' });

                // Icono indicativo del log
                let iconMarkup = `<i data-lucide="message-square" class="w-3.5 h-3.5 text-slate-500"></i>`;
                let iconBg = 'bg-slate-100 border-slate-200';
                
                if (log.type === 'create') {
                    iconMarkup = `<i data-lucide="file-plus" class="w-3.5 h-3.5 text-indigo-600"></i>`;
                    iconBg = 'bg-indigo-50 border-indigo-200';
                } else if (log.type === 'transition') {
                    iconMarkup = `<i data-lucide="arrow-right-left" class="w-3.5 h-3.5 text-amber-600"></i>`;
                    iconBg = 'bg-amber-50 border-amber-200';
                } else if (log.type === 'comment') {
                    iconMarkup = `<i data-lucide="message-circle" class="w-3.5 h-3.5 text-emerald-600"></i>`;
                    iconBg = 'bg-emerald-50 border-emerald-200';
                }

                item.innerHTML = `
                    <div class="absolute left-0 mt-0.5 w-6.5 h-6.5 rounded-full ${iconBg} border flex items-center justify-center z-10">
                        ${iconMarkup}
                    </div>
                    <div>
                        <div class="flex items-center gap-2">
                            <span class="text-xs font-bold text-slate-800">
                                ${log.type === 'create' ? 'Registro e Ingreso Inicial' : 
                                  log.type === 'transition' ? `Movido a ${getStatusPrettyName(log.to)}` : 'Comentario Directo / Bitácora'}
                            </span>
                            <span class="text-[10px] text-slate-400 font-semibold">${dateString}</span>
                        </div>
                        ${log.from ? `<p class="text-[10px] text-slate-400 font-medium">Flujo: ${getStatusPrettyName(log.from)} &rarr; ${getStatusPrettyName(log.to)}</p>` : ''}
                        <p class="text-xs text-slate-600 bg-slate-50 p-2 rounded-lg border border-slate-100 mt-1 italic">
                            "${log.text}"
                        </p>
                    </div>
                `;
                timelineContainer.appendChild(item);
            });

            // Abrir Modal
            document.getElementById('modalDetails').classList.remove('hidden');
            lucide.createIcons();
        }

        // Cerrar modal de detalles
        function closeDetailsModal() {
            document.getElementById('modalDetails').classList.add('hidden');
            document.getElementById('directCommentInput').value = '';
            currentViewingProductId = null;
        }

        // Añadir comentario de progreso independiente directo a la bitácora
        function addDirectComment() {
            const commentText = document.getElementById('directCommentInput').value.trim();
            if (!commentText) return;

            const prod = products.find(p => p.id === currentViewingProductId);
            if (prod) {
                prod.history.push({
                    timestamp: new Date().toISOString(),
                    text: commentText,
                    type: "comment",
                    from: null,
                    to: null
                });

                saveToStorage();
                openDetailsModal(prod.id);
                renderBoard();
                document.getElementById('directCommentInput').value = '';
            }
        }

        // Abrir Modal de eliminación personalizado (Reemplaza confirm() para evitar errores en iframe)
        function openDeleteModal(productId) {
            const prod = products.find(p => p.id === productId);
            if (!prod) return;

            pendingDeleteId = productId;
            document.getElementById('deleteModalMessage').innerHTML = `¿Estás completamente seguro de eliminar el registro de este equipo? <br><strong class="text-slate-800">${prod.product}</strong> (S/N: ${prod.serial})`;
            
            // Vincular evento de confirmación al botón
            const btnConfirm = document.getElementById('btnConfirmDelete');
            btnConfirm.onclick = executeDelete;

            document.getElementById('modalDelete').classList.remove('hidden');
            lucide.createIcons();
        }

        // Cerrar modal de eliminación
        function closeDeleteModal() {
            document.getElementById('modalDelete').classList.add('hidden');
            pendingDeleteId = null;
        }

        // Ejecutar eliminación del registro de producto
        function executeDelete() {
            if (!pendingDeleteId) return;

            products = products.filter(p => p.id !== pendingDeleteId);
            saveToStorage();
            renderBoard();
            closeDeleteModal();
        }

        // Buscador Inteligente para Filtrar Equipos (Filtra y refresca el tablero Kanban)
        function filterProducts() {
            renderBoard();
        }
    </script>
</body>
