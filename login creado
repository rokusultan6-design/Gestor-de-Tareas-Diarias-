                    return false;
                }

                const matchesStatus = (statusFilter === 'ALL') || (prod.status === statusFilter);
                
                const matchesQuery = query === '' ||
                    prod.product.toLowerCase().includes(query) ||
                    (prod.receiptCode && prod.receiptCode.toLowerCase().includes(query)) ||
                    (prod.workshopOrderNumber && prod.workshopOrderNumber.toLowerCase().includes(query)) ||
                    (prod.repairDetails && prod.repairDetails.toLowerCase().includes(query)) ||
                    prod.serial.toLowerCase().includes(query) ||
                    prod.client.toLowerCase().includes(query) ||
                    (prod.phone && prod.phone.toLowerCase().includes(query)) ||
                    (prod.store && prod.store.toLowerCase().includes(query)) ||
                    (prod.workshop && prod.workshop.toLowerCase().includes(query)) ||
                    prod.desc.toLowerCase().includes(query);

                return matchesStatus && matchesQuery;
            });

            const totalUserScopeProducts = products.filter(p => !currentUser || currentUser.allowedStores.includes(p.store)).length;

            counterBadge.innerText = `${filteredProducts.length} de ${totalUserScopeProducts} Registros`;

