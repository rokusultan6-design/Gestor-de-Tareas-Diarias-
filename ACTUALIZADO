                opt.value = brand;
                opt.innerText = brand;
                brandSelect.appendChild(opt);
            });

            // 2. Limpiar e Insertar Casillas de Verificación de Accesorios
            accContainer.innerHTML = '';
            config.accessories.forEach(acc => {
                const label = document.createElement('label');
                label.className = "flex items-center gap-2 cursor-pointer bg-white p-2 rounded-lg border border-slate-200 hover:bg-indigo-50/40 transition-colors shadow-sm select-none";
                
