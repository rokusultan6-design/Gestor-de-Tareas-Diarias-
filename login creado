                    </td>
                    <td class="py-3 px-4 font-semibold text-slate-600">
                        <span class="inline-flex items-center gap-1"><i data-lucide="store" class="w-3 h-3 text-indigo-500"></i> ${prod.store || 'Dos Hermanos'}</span>
                    </td>
                    <td class="py-3 px-4 whitespace-nowrap">
                        ${statusBadge}
