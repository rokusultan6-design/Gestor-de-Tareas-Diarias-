        // Obtener la cantidad de días transcurridos sin novedades en taller
        function getDaysSinceActivityInWorkshop(prod) {
            if (prod.status !== 'taller') return 0;
            const startRef = prod.lastInquiryAt ? prod.lastInquiryAt : prod.enteredTallerAt;
            if (!startRef) return 0;

            const diffTime = Date.now() - new Date(startRef).getTime();
            return Math.floor(diffTime / (1000 * 60 * 60 * 24));
        }

        // Renderizar todo el tablero Kanban con soporte de archivado automático, buscador y recordatorios de 5 días
        function renderBoard() {
            const colEntrada = document.getElementById('col-entrada');
            const colTaller = document.getElementById('col-taller');
            const colRetornado = document.getElementById('col-retornado');
            const colEntregado = document.getElementById('col-entregado');

            // Limpiar columnas
            colEntrada.innerHTML = '';
            colTaller.innerHTML = '';
            colRetornado.innerHTML = '';
            colEntregado.innerHTML = '';

            let countEnt = 0, countTal = 0, countRet = 0, countEntregadoActivos = 0;
            let countFollowUpAlerts = 0;

            const searchQuery = document.getElementById('searchInput') ? document.getElementById('searchInput').value.toLowerCase().trim() : '';

            products.forEach(prod => {
                // Calcular alertas en taller
                if (prod.status === 'taller') {
                    const days = getDaysSinceActivityInWorkshop(prod);
                    if (days >= 5) {
                        countFollowUpAlerts++;
                    }
                }

                const card = createProductCard(prod);
                
                // Determinar si coincide con la búsqueda (Incluye filtro por tienda, teléfono y número de serie completo)
                const matchesSearch = searchQuery === '' || 
                    prod.product.toLowerCase().includes(searchQuery) || 
                    prod.serial.toLowerCase().includes(searchQuery) || 
                    prod.client.toLowerCase().includes(searchQuery) ||
                    (prod.phone && prod.phone.toLowerCase().includes(searchQuery)) ||
                    (prod.store && prod.store.toLowerCase().includes(searchQuery)) ||
                    prod.desc.toLowerCase().includes(searchQuery);

                if (prod.status === 'entrada') {
                    if (matchesSearch) {
                        colEntrada.appendChild(card);
                        countEnt++;
                    }
                } else if (prod.status === 'taller') {
                    if (matchesSearch) {
                        colTaller.appendChild(card);
                        countTal++;
                    }
                } else if (prod.status === 'retornado') {
                    if (matchesSearch) {
                        colRetornado.appendChild(card);
                        countRet++;
                    }
                } else if (prod.status === 'entregado') {
                    // Lógica de archivado temporal (24 horas)
                    const timeElapsed = prod.deliveredAt ? (Date.now() - new Date(prod.deliveredAt).getTime()) : 0;
                    const isArchived = timeElapsed > ARCHIVE_TIMEOUT_MS;

                    if (searchQuery !== '') {
                        // En caso de que se use el buscador, forzamos a que aparezcan siempre, incluso si ya fueron archivados
                        if (matchesSearch) {
                            colEntregado.appendChild(card);
                            countEntregadoActivos++;
                        }
                    } else {
                        // Sin búsqueda, solo renderizar los recientes (No archivados en el lapso de 24 horas)
                        if (!isArchived) {
                            colEntregado.appendChild(card);
                            countEntregadoActivos++;
                        }
                    }
                }
            });

            // Actualizar contadores en la interfaz
            document.getElementById('countEntrada').innerText = countEnt;
            document.getElementById('countTaller').innerText = countTal;
            document.getElementById('countRetornado').innerText = countRet;
            document.getElementById('countEntregado').innerText = countEntregadoActivos;

            // Stats del dashboard
            document.getElementById('statTotal').innerText = products.length;
            document.getElementById('statEntrada').innerText = countEnt;
            document.getElementById('statTaller').innerText = countTal;
            document.getElementById('statRetornado').innerText = countRet;
            document.getElementById('statEntregado').innerText = countEntregadoActivos;

            // Mostrar/Ocultar Banner global de alertas de 5 días
            const followUpBanner = document.getElementById('followUpAlertBanner');
            const pendingBadge = document.getElementById('pendingAlertsBadge');
            if (countFollowUpAlerts > 0) {
                followUpBanner.classList.remove('hidden');
                pendingBadge.innerText = `${countFollowUpAlerts} equipo(s) con alerta`;
            } else {
                followUpBanner.classList.add('hidden');
            }

            lucide.createIcons();
        }

