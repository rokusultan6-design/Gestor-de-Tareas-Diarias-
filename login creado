                    <div class="flex items-center justify-between">
                        <span class="font-medium text-slate-700 flex items-center gap-1"><i data-lucide="user" class="w-3 h-3 text-slate-400"></i> ${prod.client}</span>
                        <span class="font-mono text-slate-500 flex items-center gap-1"><i data-lucide="phone" class="w-3 h-3 text-slate-400"></i> ${prod.phone || '--'}</span>
                    </div>
                    <div class="flex items-center justify-between text-[10px] text-slate-400 pt-0.5">
                        <span class="flex items-center gap-1 font-semibold text-indigo-600"><i data-lucide="store" class="w-3 h-3 text-indigo-400"></i> ${prod.store || 'Dos Hermanos'}</span>
                    </div>
                </div>

                ${followUpBtn}

                <div class="pt-1 flex items-center gap-2">
                    ${flowButtons}
                </div>
            `;

            return card;
        }

        // --- ARRASTRE Y SOLTADO (DRAG & DROP) ---
        function handleDragStart(e, prodId) {
            e.dataTransfer.setData('text/plain', prodId);
        }

        function allowDrop(e) {
            e.preventDefault();
        }

        function handleDrop(e, targetStatus) {
            e.preventDefault();
            const prodId = e.dataTransfer.getData('text/plain');
            const prod = products.find(p => p.id === prodId);
            if (prod && prod.status !== targetStatus) {
                startTransition(prodId, targetStatus);
            }
        }

        // --- MANEJO DE REGISTRO DE NUEVO PRODUCTO ---
        function openNewProductModal() {
            buildStoreRadioButtons();
            document.getElementById('modalNewProduct').classList.remove('hidden');
        }

        function closeNewProductModal() {
            document.getElementById('modalNewProduct').classList.add('hidden');
            document.getElementById('productForm').reset();
            handleArticleTypeChange();
        }

        function saveProduct(e) {
            e.preventDefault();
            
            const selectedStoreRadio = document.querySelector('input[name="store"]:checked');
            const storeVal = selectedStoreRadio ? selectedStoreRadio.value : (currentUser ? currentUser.allowedStores[0] : "Dos Hermanos");

            let articleTypeVal = document.getElementById('prodArticleType').value;
            if (articleTypeVal === 'Otro') {
                articleTypeVal = document.getElementById('prodArticleTypeCustom').value.trim() || 'Otro';
            }

            let brandVal = document.getElementById('prodBrand').value;
            if (brandVal === 'Otro') {
                brandVal = document.getElementById('prodBrandCustom').value.trim() || 'Otra Marca';
            }

            const modelVal = document.getElementById('prodModel').value.trim();
            const fullTitle = `${articleTypeVal} ${brandVal} - ${modelVal}`;

            // Capturar Accesorios seleccionados
            const accCheckboxes = document.querySelectorAll('input[name="prodAccessories"]:checked');
            let selectedAccessories = [];
            accCheckboxes.forEach(cb => {
                if (cb.value === 'Otro') {
                    const customAcc = document.getElementById('prodAccessoryCustom').value.trim();
                    if (customAcc) selectedAccessories.push(customAcc);
                } else {
                    selectedAccessories.push(cb.value);
                }
            });

            if (selectedAccessories.length === 0) {
                selectedAccessories = ["Solo equipo principal"];
            }

            const receiptCode = getNextReceiptCode();

            const newProd = {
                id: 'prod-' + Date.now(),
                receiptCode: receiptCode,
                product: fullTitle,
                articleType: articleTypeVal,
                brand: brandVal,
                model: modelVal,
                accessories: selectedAccessories,
                serial: document.getElementById('prodSerial').value.trim(),
                client: document.getElementById('prodClient').value.trim(),
                phone: document.getElementById('prodPhone').value.trim(),
                store: storeVal,
                desc: document.getElementById('prodDesc').value.trim(),
                priority: document.querySelector('input[name="priority"]:checked').value,
                status: 'entrada',
                workshop: null,
                workshopOrderNumber: null,
                repairDetails: null,
                createdAt: new Date().toISOString(),
                enteredTallerAt: null,
                lastInquiryAt: null,
                history: [
                    {
                        timestamp: new Date().toISOString(),
                        text: `Producto ingresado en tienda ${storeVal}. Accesorios: ${selectedAccessories.join(', ')}.`,
                        type: "create",
                        from: null,
                        to: "entrada"
                    }
                ]
            };

            products.unshift(newProd);
            saveToStorage();
            closeNewProductModal();
            renderBoard();

            openReceiptModal(newProd.id);
        }

        // --- TRANSICIONES Y MODAL DE CAMBIO DE ESTADO ---
        function startTransition(prodId, newStatus) {
            const prod = products.find(p => p.id === prodId);
            if (!prod) return;

            pendingTransition = { prodId, newStatus };
            
            const notice = document.getElementById('transitionNotice');
            const quickBox = document.getElementById('quickComments');
            const workshopBlock = document.getElementById('workshopSelectBlock');
            const returnBlock = document.getElementById('workshopReturnBlock');
            const errBlock = document.getElementById('transitionErrorMsg');

            document.getElementById('transitionComment').value = '';
            document.getElementById('transitionWorkshopOrder').value = prod.workshopOrderNumber || '';
            document.getElementById('transitionRepairDetails').value = prod.repairDetails || '';
            
            errBlock.classList.add('hidden');
            workshopBlock.classList.add('hidden');
            returnBlock.classList.add('hidden');
            quickBox.innerHTML = '';

            let statusNames = {
                'entrada': '1. Entrada / Recepción',
                'taller': '2. En Taller',
                'retornado': '3. Retornado de Taller (Listo p/ Entrega)',
                'entregado': '4. Entregado a Cliente'
            };

            notice.innerText = `Cambiando de [${statusNames[prod.status]}] a [${statusNames[newStatus]}].`;

            if (newStatus === 'taller') {
                workshopBlock.classList.remove('hidden');
            } else if (newStatus === 'retornado') {
                returnBlock.classList.remove('hidden');
            }

            const options = {
                'taller': ['Se envía a taller técnico para diagnóstico.', 'Ingresa a reparación prioritaria.', 'En espera de revisión técnica.'],
                'retornado': ['Equipo reparado exitosamente.', 'Pruebas finalizadas con éxito.', 'Sin reparación por costo/repuesto.'],
                'entregado': ['Cliente retira en tienda conforme.', 'Entregado a familiar autorizado.', 'Pruebas realizadas ante el cliente.'],
                'entrada': ['Regresado a recepción para verificación.', 'A la espera de autorización.']
            };

            (options[newStatus] || []).forEach(text => {
                const btn = document.createElement('button');
                btn.type = 'button';
                btn.className = "text-[10px] bg-slate-100 hover:bg-indigo-50 hover:text-indigo-600 text-slate-600 px-2 py-1 rounded border border-slate-200 transition-colors";
                btn.innerText = text;
                btn.onclick = () => document.getElementById('transitionComment').value = text;
                quickBox.appendChild(btn);
            });

            document.getElementById('modalTransition').classList.remove('hidden');
            lucide.createIcons();
        }

        function cancelTransition() {
            pendingTransition = null;
            document.getElementById('modalTransition').classList.add('hidden');
        }

        function applyQuickRepair(text) {
            document.getElementById('transitionRepairDetails').value = text;
        }

        function confirmTransition() {
            if (!pendingTransition) return;

            const { prodId, newStatus } = pendingTransition;
            const prod = products.find(p => p.id === prodId);
            if (!prod) return;

            const comment = document.getElementById('transitionComment').value.trim();
            const errBlock = document.getElementById('transitionErrorMsg');

            let selectedWorkshop = null;
            let orderNumber = null;
            let repairDetails = null;

            if (newStatus === 'taller') {
                selectedWorkshop = document.getElementById('transitionWorkshop').value;
            } else if (newStatus === 'retornado') {
                orderNumber = document.getElementById('transitionWorkshopOrder').value.trim();
                repairDetails = document.getElementById('transitionRepairDetails').value.trim();

                if (!orderNumber || !repairDetails) {
                    errBlock.classList.remove('hidden');
                    return;
                }
            }

            const prevStatus = prod.status;
            prod.status = newStatus;

            if (newStatus === 'taller') {
                prod.workshop = selectedWorkshop;
                prod.enteredTallerAt = new Date().toISOString();
                prod.lastInquiryAt = null;
            } else if (newStatus === 'retornado') {
                prod.workshopOrderNumber = orderNumber;
                prod.repairDetails = repairDetails;
            } else if (newStatus === 'entregado') {
                prod.deliveredAt = new Date().toISOString();
            }

            let transitionText = `Estado cambiado a ${newStatus.toUpperCase()}`;
            if (newStatus === 'taller') transitionText += ` (Taller: ${selectedWorkshop})`;
            if (newStatus === 'retornado') transitionText += ` (N° Orden: ${orderNumber})`;
            if (comment) transitionText += ` - Nota: ${comment}`;

            prod.history.unshift({
                timestamp: new Date().toISOString(),
                text: transitionText,
                type: "transition",
                from: prevStatus,
                to: newStatus
            });

            saveToStorage();
            document.getElementById('modalTransition').classList.add('hidden');
            pendingTransition = null;
            renderBoard();
        }

        // --- GESTIÓN DE CONSULTAS (REINICIO DE ALERTA DE 5 DÍAS) ---
        function openInquiryModal(prodId) {
            pendingInquiryProductId = prodId;
            const prod = products.find(p => p.id === prodId);
            if (!prod) return;

            const days = getDaysSinceActivityInWorkshop(prod);
            document.getElementById('inquiryProductText').innerHTML = `
                El equipo <strong>${prod.product}</strong> tiene <strong>${days} días</strong> en el taller <strong>${prod.workshop || 'Taller'}</strong>.
                Registra la gestión realizada para reiniciar el contador.
            `;
            document.getElementById('inquiryComment').value = '';
            document.getElementById('inquiryErrorMsg').classList.add('hidden');
            document.getElementById('modalInquiry').classList.remove('hidden');
        }

        function closeInquiryModal() {
            pendingInquiryProductId = null;
            document.getElementById('modalInquiry').classList.add('hidden');
        }

        function applyQuickInquiry(text) {
            document.getElementById('inquiryComment').value = text;
        }

        function saveInquiryManagement() {
            if (!pendingInquiryProductId) return;

            const note = document.getElementById('inquiryComment').value.trim();
            const errEl = document.getElementById('inquiryErrorMsg');

            if (!note) {
                errEl.classList.remove('hidden');
                return;
            }

            const prod = products.find(p => p.id === pendingInquiryProductId);
            if (!prod) return;

            prod.lastInquiryAt = new Date().toISOString();
            prod.history.unshift({
                timestamp: new Date().toISOString(),
                text: `GESTIÓN DE SEGUIMIENTO (Taller ${prod.workshop}): ${note}`,
                type: "inquiry",
                from: prod.status,
                to: prod.status
            });

            saveToStorage();
            closeInquiryModal();
            renderBoard();
        }

        // --- MODAL DE DETALLES Y BITÁCORA ---
        function openDetailsModal(prodId) {
            currentViewingProductId = prodId;
            const prod = products.find(p => p.id === prodId);
            if (!prod) return;

            document.getElementById('detailTitle').innerText = prod.product;
            document.getElementById('detailArticleType').innerText = prod.articleType || 'N/A';
            document.getElementById('detailBrand').innerText = prod.brand || 'N/A';
            document.getElementById('detailStore').innerText = prod.store || 'Dos Hermanos';
            document.getElementById('detailSerial').innerText = prod.serial;
            document.getElementById('detailClient').innerText = prod.client;
            document.getElementById('detailPhone').innerText = prod.phone || 'Sin teléfono';
            document.getElementById('detailDesc').innerText = prod.desc;

            // Renderizar insignias
            const statusEl = document.getElementById('detailStatus');
            statusEl.innerText = prod.status.toUpperCase();
            if (prod.status === 'entrada') statusEl.className = "text-xs px-2.5 py-0.5 rounded-full font-bold bg-sky-100 text-sky-800 border border-sky-200";
            else if (prod.status === 'taller') statusEl.className = "text-xs px-2.5 py-0.5 rounded-full font-bold bg-amber-100 text-amber-800 border border-amber-200";
            else if (prod.status === 'retornado') statusEl.className = "text-xs px-2.5 py-0.5 rounded-full font-bold bg-emerald-100 text-emerald-800 border border-emerald-200";
            else if (prod.status === 'entregado') statusEl.className = "text-xs px-2.5 py-0.5 rounded-full font-bold bg-indigo-100 text-indigo-800 border border-indigo-200";

            const prioEl = document.getElementById('detailPriority');
            prioEl.innerText = "Prioridad: " + prod.priority;
            if (prod.priority === 'Alta') prioEl.className = "text-xs px-2.5 py-0.5 rounded-full font-bold bg-rose-100 text-rose-800 border border-rose-200";
            else if (prod.priority === 'Media') prioEl.className = "text-xs px-2.5 py-0.5 rounded-full font-bold bg-amber-100 text-amber-800 border border-amber-200";
            else prioEl.className = "text-xs px-2.5 py-0.5 rounded-full font-bold bg-emerald-100 text-emerald-800 border border-emerald-200";

            const wsBadge = document.getElementById('detailWorkshopBadge');
            if (prod.workshop) {
                wsBadge.innerText = "Taller: " + prod.workshop;
                wsBadge.className = "text-xs px-2.5 py-0.5 rounded-full font-bold bg-purple-100 text-purple-800 border border-purple-200 inline-block";
                wsBadge.classList.remove('hidden');
            } else {
                wsBadge.classList.add('hidden');
            }

            // Tarjeta de Reparación de Taller en Detalles
            const repairBox = document.getElementById('detailWorkshopRepairBox');
            if (prod.repairDetails && prod.workshopOrderNumber) {
                document.getElementById('detailWorkshopOrderTag').innerText = "Orden N° " + prod.workshopOrderNumber;
                document.getElementById('detailWorkshopRepairText').innerText = prod.repairDetails;
                repairBox.classList.remove('hidden');
            } else {
                repairBox.classList.add('hidden');
            }

            // Renderizar accesorios
            const accEl = document.getElementById('detailAccessories');
            accEl.innerHTML = '';
            if (prod.accessories && prod.accessories.length > 0) {
                prod.accessories.forEach(acc => {
                    const tag = document.createElement('span');
                    tag.className = "text-xs font-semibold px-2.5 py-1 bg-white border border-slate-200 rounded-md text-slate-700 shadow-2xs";
                    tag.innerText = acc;
                    accEl.appendChild(tag);
                });
            } else {
                accEl.innerHTML = '<span class="text-xs text-slate-400 italic">Sin accesorios registrados</span>';
            }

            // Timeline / Bitácora
            const timeline = document.getElementById('detailTimeline');
            timeline.innerHTML = '';
            prod.history.forEach(item => {
                const itemDate = new Date(item.timestamp);
                const timeStr = itemDate.toLocaleDateString('es-ES', { day: '2-digit', month: '2-digit', year: 'numeric' }) + ' ' + itemDate.toLocaleTimeString('es-ES', { hour: '2-digit', minute: '2-digit' });

                const div = document.createElement('div');
                div.className = "relative pl-6 text-xs";

                let dotColor = "bg-indigo-500";
                if (item.type === 'create') dotColor = "bg-sky-500";
                if (item.type === 'inquiry') dotColor = "bg-amber-500";
                if (item.to === 'retornado') dotColor = "bg-emerald-500";

                div.innerHTML = `
                    <div class="absolute left-1.5 top-1 w-3 h-3 ${dotColor} rounded-full border-2 border-white shadow-xs"></div>
                    <p class="font-bold text-slate-800">${item.text}</p>
                    <p class="text-[10px] text-slate-400 font-mono mt-0.5">${timeStr}</p>
                `;
                timeline.appendChild(div);
            });

            document.getElementById('modalDetails').classList.remove('hidden');
            lucide.createIcons();
        }

        function closeDetailsModal() {
            currentViewingProductId = null;
            document.getElementById('modalDetails').classList.add('hidden');
        }

        function addDirectComment() {
            if (!currentViewingProductId) return;
            const input = document.getElementById('directCommentInput');
            const comment = input.value.trim();
            if (!comment) return;

            const prod = products.find(p => p.id === currentViewingProductId);
            if (!prod) return;

            prod.history.unshift({
                timestamp: new Date().toISOString(),
                text: `Nota: ${comment}`,
                type: "note",
                from: prod.status,
                to: prod.status
            });

            saveToStorage();
            input.value = '';
            openDetailsModal(currentViewingProductId);
        }

        function reprintFromDetails() {
            if (currentViewingProductId) {
                openReceiptModal(currentViewingProductId);
            }
        }

        // --- COMPROBANTE DE INGRESO Y VISTA PREVIA ---
        function openReceiptModal(prodId) {
            const prod = products.find(p => p.id === prodId);
            if (!prod) return;

            const storeInfo = STORES_INFO[prod.store] || STORES_INFO["Dos Hermanos"];

            document.getElementById('receiptNumber').innerText = "N° " + (prod.receiptCode || '0000');
            document.getElementById('receiptHeaderStore').innerText = "Tienda: " + (prod.store || "Dos Hermanos");
            
            document.getElementById('receiptStoreAddress').querySelector('span').innerText = storeInfo.address;
            document.getElementById('receiptStorePhone').innerText = storeInfo.phone;
            document.getElementById('receiptStoreEmail').innerText = storeInfo.email;

            document.getElementById('receiptClientName').innerText = prod.client;
            document.getElementById('receiptClientPhone').innerText = prod.phone || 'N/A';
            
            const createdDate = new Date(prod.createdAt);
            document.getElementById('receiptDate').innerText = "Fecha: " + createdDate.toLocaleDateString('es-ES', { day: '2-digit', month: '2-digit', year: 'numeric' });
            document.getElementById('receiptDateTime').innerText = createdDate.toLocaleString('es-ES', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' });

            document.getElementById('receiptArticleType').innerText = prod.articleType || 'Servicio Técnico';
            document.getElementById('receiptBrand').innerText = prod.brand || 'N/A';
            document.getElementById('receiptModel').innerText = prod.model || prod.product;
            document.getElementById('receiptSerial').innerText = prod.serial;
            document.getElementById('receiptDiagnostic').innerText = prod.desc;

            // Bloque dinámico de Reparación en Recibo
            const repairBlock = document.getElementById('receiptRepairBlock');
            if (prod.repairDetails && prod.workshopOrderNumber) {
                document.getElementById('receiptWorkshopOrderLabel').innerText = "N° Orden Taller: " + prod.workshopOrderNumber;
                document.getElementById('receiptRepairText').innerText = prod.repairDetails;
                repairBlock.classList.remove('hidden');
            } else {
                repairBlock.classList.add('hidden');
            }

            const accContainer = document.getElementById('receiptAccessories');
            accContainer.innerHTML = '';
            if (prod.accessories && prod.accessories.length > 0) {
                prod.accessories.forEach(acc => {
                    const tag = document.createElement('span');
                    tag.className = "text-[11px] font-semibold px-2 py-0.5 bg-indigo-50 border border-indigo-200 rounded text-indigo-900";
                    tag.innerText = acc;
                    accContainer.appendChild(tag);
                });
            } else {
                accContainer.innerHTML = '<span class="text-xs text-slate-400 italic">Ningún accesorio entregado</span>';
            }

            document.getElementById('modalReceipt').classList.remove('hidden');
            lucide.createIcons();
        }

        function closeReceiptModal() {
            document.getElementById('modalReceipt').classList.add('hidden');
        }

        function printReceipt() {
            window.print();
        }

        // --- ELIMINACIÓN DE REGISTROS ---
        function openDeleteModal(prodId) {
            pendingDeleteId = prodId;
            const prod = products.find(p => p.id === prodId);
            if (!prod) return;

            document.getElementById('deleteModalMessage').innerText = `¿Estás seguro de eliminar el equipo "${prod.product}" (S/N: ${prod.serial})? Esta acción no se puede deshacer.`;
            document.getElementById('btnConfirmDelete').onclick = confirmDelete;
            document.getElementById('modalDelete').classList.remove('hidden');
        }

        function closeDeleteModal() {
            pendingDeleteId = null;
            document.getElementById('modalDelete').classList.add('hidden');
        }

        function confirmDelete() {
            if (!pendingDeleteId) return;

            products = products.filter(p => p.id !== pendingDeleteId);
            saveToStorage();
            closeDeleteModal();
            renderBoard();
        }
    </script>
</body>
</html>
